# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://bearduser:beardpass123@postgres:5432/beard_style_db

# For local development without Docker use:
# DATABASE_URL=postgresql://bearduser:beardpass123@localhost:5433/beard_style_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Claude AI Configuration
CLAUDE_API_KEY=your_claude_api_key_here

# IMPORTANT: Replace 'your_claude_api_key_here' with your actual Claude API key
# Get your API key from: https://console.anthropic.com/settings/keys
# Documentation: https://docs.anthropic.com/
