# ===========================================
# BEARD STYLE APP - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!
# ===========================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# For Docker: use postgres as host
# For local: use localhost
DATABASE_URL=postgresql://bearduser:beardpass123@postgres:5432/beard_style_db
POSTGRES_USER=bearduser
POSTGRES_PASSWORD=beardpass123
POSTGRES_DB=beard_style_db

# JWT Configuration
# IMPORTANT: Generate a strong secret for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ===========================================
# AI API Keys - GET YOUR OWN KEYS
# ===========================================

# Claude AI (Anthropic) - for face analysis
# Get your key at: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI DALL-E - for image generation
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Claude model ID — override to use a specific version
# Leave blank to use the default fallback in claudeService.js
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Set to 'true' to use mock AI responses (for development without API keys)
USE_MOCK_AI=true
